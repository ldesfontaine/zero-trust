# Managed by Ansible — ne pas modifier manuellement
# Variables d'environnement pour le container bientot
# Aligné sur le .env.example du repo bientot

# --- Ntfy notifications ---
NTFY_SERVER_URL={{ vault_ntfy_server_url | default('https://' + ntfy_subdomain + '.' + vault_base_domain) }}
NTFY_TOPIC={{ vault_ntfy_alert_topic | default('alerts') }}

# --- Scraping targets ---
# netbird_bind_ip est calculé par le role netbird-resolve (fact per-host).
# Pour les URLs cross-host (VPS), on utilise vault_vps_netbird_ip avec guard.
{% set vps_nb = vault_vps_netbird_ip if vault_vps_netbird_ip not in ['CHANGE_ME', 'REMPLACER_APRES_ENROLEMENT_NETBIRD'] else '127.0.0.1' %}
NODE_EXPORTER_PI_URL=http://{{ netbird_bind_ip }}:9100
NODE_EXPORTER_VPS_URL=http://{{ vps_nb }}:9100
CROWDSEC_METRICS_URL=http://{{ vps_nb }}:6060

# --- Backup status ---
BACKUP_STATUS_DIR={{ pi_stack_dir }}/backup/status

# --- Web ---
WEB_PORT={{ bientot_port }}
