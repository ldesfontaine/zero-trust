# ============================================================================
# SSH Hardened Configuration — Managed by Ansible
# Ne pas modifier manuellement — relancer le playbook pour tout changement
# ============================================================================

Port {{ ssh_port }}
AddressFamily any
ListenAddress 0.0.0.0
ListenAddress ::

# --- Authentification ---
PermitRootLogin no
MaxAuthTries {{ ssh_max_auth_tries }}
MaxSessions {{ ssh_max_sessions }}
PubkeyAuthentication yes
PasswordAuthentication no
PermitEmptyPasswords no
KbdInteractiveAuthentication no
UsePAM yes
AuthenticationMethods publickey

# --- Restriction d'accès ---
AllowUsers {{ ssh_user }} {{ vault_deploy_user }}

# --- Timeouts ---
LoginGraceTime 30
TCPKeepAlive yes
ClientAliveInterval {{ ssh_client_alive_interval }}
ClientAliveCountMax {{ ssh_client_alive_count_max }}

# --- Concurrence (évite MaxStartups lors des runs Ansible) ---
MaxStartups 20:50:100

# --- Surface d'attaque réduite ---
X11Forwarding no
PrintMotd no
PermitUserEnvironment no
AllowAgentForwarding yes
AllowTcpForwarding no
PermitTunnel no

# --- Logging (VERBOSE pour CrowdSec) ---
SyslogFacility AUTH
LogLevel VERBOSE

# --- SFTP ---
Subsystem sftp /usr/lib/openssh/sftp-server

# --- Algorithmes modernes (post-2020) ---
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
