# ============================================================================
# Docker Compose Backbone — Managed by Ansible — ne pas modifier manuellement
#
# Stack L3 : Traefik (reverse proxy + TLS) + NetBird server + dashboard
# ============================================================================

services:

  # == DOCKER SOCKET PROXY =====================================================
  # Protège le socket Docker — seuls les endpoints lecture sont exposés.
  # Traefik (backbone) et CrowdSec/bientot-agent (sentinel) passent par ce proxy.

  docker-proxy:
    image: tecnativa/docker-socket-proxy:{{ docker_socket_proxy_version }}
    container_name: docker-proxy
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      CONTAINERS: 1
      NETWORKS: 1
      VOLUMES: 1
      INFO: 1
      EVENTS: 1
      POST: 0
      BUILD: 0
      COMMIT: 0
      CONFIGS: 0
      DISTRIBUTION: 0
      EXEC: 0
      IMAGES: 0
      NODES: 0
      PLUGINS: 0
      SECRETS: 0
      SERVICES: 0
      SESSION: 0
      SWARM: 0
      SYSTEM: 0
      TASKS: 0
    networks:
      - sentinel_net
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:2375/version || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3

  # == REVERSE PROXY ===========================================================

  traefik:
    image: traefik:{{ traefik_version }}
    container_name: traefik
    restart: unless-stopped
    depends_on:
      - docker-proxy
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      # NET_BIND_SERVICE requis pour bind les ports 80/443 en non-root
      - NET_BIND_SERVICE
    command:
      # Provider Docker via socket proxy (PAS de montage direct)
      - "--providers.docker.endpoint=tcp://docker-proxy:2375"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.docker.network=sentinel_net"
      # Provider fichier (services Pi via NetBird mesh)
      - "--providers.file.directory=/etc/traefik/dynamic"
      - "--providers.file.watch=true"
      # Entrypoints
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      # Timeout infini pour gRPC long-lived connections (NetBird)
      - "--entrypoints.websecure.transport.respondingTimeouts.readTimeout=0"
      # Redirect HTTP -> HTTPS
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
      # Let's Encrypt TLS Challenge
      - "--certificatesresolvers.letsencrypt.acme.tlschallenge=true"
      - "--certificatesresolvers.letsencrypt.acme.email={{ vault_admin_email }}"
      - "--certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json"
      # Healthcheck ping endpoint (interne uniquement)
      - "--ping=true"
      - "--ping.entrypoint=web"
      # Logs
      - "--log.level=INFO"
      - "--accesslog=true"
    ports:
      - '80:80'
      - '443:443'
    volumes:
      - {{ backbone_dir }}/traefik/letsencrypt:/letsencrypt
      - {{ backbone_dir }}/traefik/dynamic:/etc/traefik/dynamic:ro
    networks:
      - sentinel_net
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:80/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3

  # == NETBIRD VPN =============================================================
  # Architecture v0.65+ : container unifié (management + signal + relay + STUN)
  # Port 3478/udp : STUN direct (UDP ne passe pas par Traefik)
  # gRPC passe via Traefik (plus de binding direct 33073)

  netbird-server:
    image: netbirdio/netbird-server:{{ netbird_server_version }}
    container_name: netbird-server
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    environment:
      - NB_DISABLE_GEOLOCATION=true
    volumes:
      - {{ backbone_dir }}/netbird/data:/var/lib/netbird
      - {{ backbone_dir }}/netbird_config.yaml:/etc/netbird/config.yaml
    ports:
      - '3478:3478/udp'
      - '127.0.0.1:33080:80/tcp'
    command: ["--config", "/etc/netbird/config.yaml"]
    healthcheck:
      test: ["CMD-SHELL", "grep -q ':2328 ' /proc/net/tcp6 2>/dev/null || grep -q ':2328 ' /proc/net/tcp 2>/dev/null"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    labels:
      - "traefik.enable=true"
      # --- Router gRPC (h2c — HTTP/2 cleartext vers le container) ---
      - "traefik.http.routers.netbird-grpc.rule=Host(`{{ netbird_fqdn }}`) && (PathPrefix(`/signalexchange.SignalExchange/`) || PathPrefix(`/management.ManagementService/`) || PathPrefix(`/management.ProxyService/`))"
      - "traefik.http.routers.netbird-grpc.entrypoints=websecure"
      - "traefik.http.routers.netbird-grpc.tls=true"
      - "traefik.http.routers.netbird-grpc.tls.certresolver=letsencrypt"
      - "traefik.http.routers.netbird-grpc.service=netbird-server-h2c"
      - "traefik.http.routers.netbird-grpc.priority=20"
      # --- Router HTTP (relay WebSocket, API REST, OAuth2, OIDC) ---
      - "traefik.http.routers.netbird-backend.rule=Host(`{{ netbird_fqdn }}`) && (PathPrefix(`/relay`) || PathPrefix(`/ws-proxy/`) || PathPrefix(`/api`) || PathPrefix(`/oauth2`) || PathPrefix(`/auth`) || PathPrefix(`/.well-known`) || PathPrefix(`/instance`))"
      - "traefik.http.routers.netbird-backend.entrypoints=websecure"
      - "traefik.http.routers.netbird-backend.tls=true"
      - "traefik.http.routers.netbird-backend.tls.certresolver=letsencrypt"
      - "traefik.http.routers.netbird-backend.service=netbird-server"
      - "traefik.http.routers.netbird-backend.priority=15"
      # --- Services ---
      - "traefik.http.services.netbird-server.loadbalancer.server.port=80"
      - "traefik.http.services.netbird-server-h2c.loadbalancer.server.port=80"
      - "traefik.http.services.netbird-server-h2c.loadbalancer.server.scheme=h2c"
    networks:
      - sentinel_net

  netbird-dashboard:
    image: netbirdio/dashboard:{{ netbird_dashboard_version }}
    container_name: netbird-dashboard
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      - NETBIRD_MGMT_API_ENDPOINT=https://{{ netbird_fqdn }}
      - NETBIRD_MGMT_GRPC_API_ENDPOINT=https://{{ netbird_fqdn }}
      - AUTH_AUDIENCE=netbird-dashboard
      - AUTH_CLIENT_ID=netbird-dashboard
      - AUTH_AUTHORITY=https://{{ netbird_fqdn }}/oauth2
      - AUTH_SUPPORTED_SCOPES=openid profile email offline_access
      - AUTH_USE_ID_TOKEN=false
      - USE_AUTH_PKCE=true
      - USE_AUTH0=false
      - AUTH_REDIRECT_URI=/nb-auth
      - AUTH_SILENT_REDIRECT_URI=/nb-silent-auth
      - LETSENCRYPT_DOMAIN=none
      - NGINX_SSL_PORT=443
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.netbird-dashboard.rule=Host(`{{ netbird_fqdn }}`)"
      - "traefik.http.routers.netbird-dashboard.entrypoints=websecure"
      - "traefik.http.routers.netbird-dashboard.tls=true"
      - "traefik.http.routers.netbird-dashboard.tls.certresolver=letsencrypt"
      - "traefik.http.routers.netbird-dashboard.priority=1"
      - "traefik.http.services.netbird-dashboard.loadbalancer.server.port=80"
    networks:
      - sentinel_net
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:80/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3

networks:
  sentinel_net:
    external: true
