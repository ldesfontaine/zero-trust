# Managed by Ansible — ne pas modifier manuellement
# Secrets Bientôt agent VPS — déployé mode 0600

# --- Agent Bientôt VPS ---
# L'agent collecte les métriques via les APIs des services sur sentinel_net
# Il ne monte PAS /proc ni /sys — tout passe par node-exporter et les APIs
BIENTOT_SERVER_URL=http://{{ vault_pi_netbird_ip }}:{{ bientot_agent_port }}
BIENTOT_MACHINE_ID=sentinelle
BIENTOT_TOKEN={{ vault_bientot_token_vps }}
DOCKER_HOST=tcp://docker-proxy:2375

# --- URLs des APIs locales (sentinel_net) ---
NODE_EXPORTER_URL=http://node-exporter:9100
CROWDSEC_URL=http://crowdsec:8080
CROWDSEC_API_KEY={{ vault_crowdsec_bientot_key }}

# --- Vérification TLS des certificats publics ---
CERT_DOMAINS={{ cert_check_domains | default('') }}

# --- Détection mesh : dial le peer distant sur un port ouvert dans les ACLs ---
NETBIRD_PEER_IP={{ vault_pi_netbird_ip }}
NETBIRD_PEER_PORT={{ bientot_agent_port }}
