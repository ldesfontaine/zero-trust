#!/usr/sbin/nft -f
# Managed by Ansible — ne pas modifier manuellement
#
# Firewall nftables VPS (Sentinelle)
# Ne PAS utiliser "flush ruleset" — ça détruit les tables NetBird/CrowdSec
# et coupe SSH pendant le reload.

# Flush ciblé : uniquement NOS tables (pas celles de NetBird/CrowdSec)
table inet filter
delete table inet filter
table ip nat
delete table ip nat

table inet filter {

  chain input {
    type filter hook input priority 0; policy drop;

    # Loopback
    iif "lo" accept

    # Connexions établies
    ct state established,related accept

    # ICMP (ping)
    ip protocol icmp accept
    ip6 nexthdr ipv6-icmp accept

    # SSH bootstrap (port 22) — sera supprimé par hardening-vps après bascule
    tcp dport 22 accept

    # SSH durci
    tcp dport {{ vault_ssh_port }} accept

    # HTTP/HTTPS (Traefik + Let's Encrypt)
    tcp dport { 80, 443 } accept

    # NetBird gRPC backward compat
    tcp dport 33073 accept

    # NetBird STUN (UDP)
    udp dport 3478 accept

    # Mesh NetBird — node-exporter + CrowdSec prometheus (Pi → VPS)
    ip saddr 100.64.0.0/10 tcp dport { 9100, 6060 } accept

    # Log et drop le reste
    counter drop
  }

  chain forward {
    type filter hook forward priority 0; policy drop;

    # Retour trafic établi
    ct state established,related accept

    # Docker : containers → internet (outbound uniquement)
    # Nécessaire : Traefik (Let's Encrypt), CrowdSec (hub), DNS
    # Ports publiés = docker-proxy (input chain), pas forward
    iifname "docker0" oifname != "docker0" accept
    iifname "br-*" oifname != "br-*" accept
  }

  chain output {
    type filter hook output priority 0; policy accept;
  }
}

# NAT pour Docker (masquerade containers → internet)
table ip nat {
  chain postrouting {
    type nat hook postrouting priority 100; policy accept;
    # Docker subnets (172.16.0.0/12) sortant vers l'extérieur
    ip saddr 172.16.0.0/12 oifname != "docker0" masquerade
  }
}
