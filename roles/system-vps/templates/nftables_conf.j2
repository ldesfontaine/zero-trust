#!/usr/sbin/nft -f
# Managed by Ansible — ne pas modifier manuellement
#
# Firewall nftables VPS (Sentinelle)
#
# REGLES DE COHABITATION (Debian 12 : iptables = iptables-nft) :
# - Ne PAS utiliser "flush ruleset" — détruit les tables Docker/NetBird/CrowdSec
# - "delete table inet filter" ne touche QUE notre table de filtrage
# - Docker gère ses tables (ip filter, ip nat) via iptables-nft — ne pas les supprimer
# - CrowdSec gère ses tables (inet crowdsec, inet crowdsec6) via le bouncer
# - NetBird gère sa table (inet nftables-netbird-acl) via le daemon
# - Le masquerade containers → internet est géré par Docker (ip nat POSTROUTING)

# Recréer UNIQUEMENT notre table inet filter.
# Les tables tierces ne sont PAS touchées :
#   - Docker : ip filter, ip nat (gérées par Docker via iptables-nft)
#   - CrowdSec : inet crowdsec, inet crowdsec6 (gérées par le bouncer)
#   - NetBird : inet nftables-netbird-acl (gérée par le daemon)
# Les jump rules que le bouncer injecte dans inet filter sont recréées
# automatiquement au restart du bouncer (handler chaîné).
table inet filter
delete table inet filter

table inet filter {

  chain input {
    type filter hook input priority 0; policy drop;

    # Loopback
    iif "lo" accept

    # Connexions établies
    ct state established,related accept

    # ICMP (ping)
    ip protocol icmp accept
    ip6 nexthdr ipv6-icmp accept

{% if (ssh_bootstrap_open | default(ansible_local.ssh_hardened.ssh_bootstrap_open | default(true))) | bool %}
    # SSH bootstrap (port 22) — désactivé automatiquement par hardening-vps
    tcp dport 22 accept
{% endif %}

    # SSH durci
    tcp dport {{ vault_ssh_port }} accept

    # HTTP/HTTPS (Traefik + Let's Encrypt)
    tcp dport { 80, 443 } accept

    # NetBird gRPC backward compat
    tcp dport 33073 accept

    # NetBird STUN (UDP)
    udp dport 3478 accept

    # Mesh NetBird — node-exporter + CrowdSec prometheus (Pi → VPS)
    ip saddr 100.64.0.0/10 tcp dport { 9100, 6060 } accept

    # Log et drop le reste
    counter drop
  }

  chain forward {
    type filter hook forward priority 0; policy drop;

    # Retour trafic établi
    ct state established,related accept

    # Docker DNAT (port publishing : host → container)
    ct status dnat accept

    # Docker : containers → internet (outbound — ports restreints)
    # DNS (53) : résolution depuis les containers
    # HTTP (80) : Let's Encrypt HTTP-01 challenge, apt-get dans containers
    # HTTPS (443) : CrowdSec hub, pulls d'images, API externes
    iifname "docker0" oifname != "docker0" tcp dport { 53, 80, 443 } accept
    iifname "docker0" oifname != "docker0" udp dport 53 accept
    iifname "br-*" oifname != "br-*" tcp dport { 53, 80, 443 } accept
    iifname "br-*" oifname != "br-*" udp dport 53 accept

    # Traefik → backends Pi via NetBird mesh
    # Le container Traefik (bridge sentinel_net = br-*) forward vers
    # le Pi (100.64.0.0/10) à travers le tunnel WireGuard.
    # Ports : PDF(8090) Portfolio(8091) Seafile(8092) Vaultwarden(8093)
    #         Immich(8096) AdGuard(3000) Bientot(3001)
    iifname "br-*" ip daddr 100.64.0.0/10 tcp dport { 3000, 3001, 8090, 8091, 8092, 8093, 8096 } accept
  }

  chain output {
    type filter hook output priority 0; policy accept;
  }
}
