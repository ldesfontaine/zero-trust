# ============================================================================
# Docker Compose Stack Pi — Managed by Ansible
# ============================================================================

{# Résolution de l'IP de binding : IP NetBird si disponible, sinon 127.0.0.1 #}
{% if vault_pi_netbird_ip == "REMPLACER_APRES_ENROLEMENT_NETBIRD" %}
{% set nb_ip = "127.0.0.1" %}
{% else %}
{% set nb_ip = vault_pi_netbird_ip %}
{% endif %}

services:

  # ══ RÉSEAU PUBLIC (accessibles via VPS → mesh → Pi, sans client VPN) ══════

  bentopdf:
    image: {{ bentopdf_image }}:{{ bentopdf_version }}
    container_name: bentopdf
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    ports:
      - '{{ nb_ip }}:8090:8080'
    networks:
      - brain_public

  portfolio:
    image: termfolio:local  # Utilise l'image construite localement sur le Pi
    container_name: portfolio
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    ports:
      - '{{ nb_ip }}:8091:80'
    networks:
      - brain_public

  # ══ RÉSEAU PRIVÉ (admin VPN seulement) ═════════════════════════════════════

  seafile-db:
    image: mariadb:{{ mariadb_version }}
    container_name: seafile-db
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - MYSQL_ROOT_PASSWORD={{ vault_seafile_db_root_password }}
      - MYSQL_LOG_CONSOLE=true
    volumes:
      - {{ pi_stack_dir }}/seafile/db:/var/lib/mysql
    networks:
      - brain_private

  memcached:
    image: memcached:{{ memcached_version }}
    container_name: seafile-memcached
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    entrypoint: memcached -m 256
    networks:
      - brain_private

  seafile:
    image: seafileltd/seafile-mc:{{ seafile_version }}
    container_name: seafile
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    depends_on:
      - seafile-db
      - memcached
    environment:
      - DB_HOST=seafile-db
      - DB_ROOT_PASSWD={{ vault_seafile_db_root_password }}
      - SEAFILE_ADMIN_EMAIL={{ vault_seafile_admin_email }}
      - SEAFILE_ADMIN_PASSWORD={{ vault_seafile_admin_password }}
      - SEAFILE_SERVER_HOSTNAME={{ seafile_subdomain }}.{{ vault_base_domain }}
      - SEAFILE_SERVER_LETSENCRYPT=false
      - FORCE_HTTPS_IN_CONF=true
    volumes:
      - {{ pi_stack_dir }}/seafile/data:/shared
    ports:
      - '{{ nb_ip }}:8092:80'
    networks:
      - brain_private

  vaultwarden:
    image: vaultwarden/server:{{ vaultwarden_version }}
    container_name: vaultwarden
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - ADMIN_TOKEN={{ vault_vaultwarden_admin_token }}
      - DOMAIN=https://{{ vaultwarden_subdomain }}.{{ vault_base_domain }}
      - SIGNUPS_ALLOWED=false
    volumes:
      - {{ pi_stack_dir }}/vaultwarden:/data
    ports:
      - '{{ nb_ip }}:8093:80'
    networks:
      - brain_private

  # ══ IMMICH (photos/vidéos) ═══════════════════════════════════════════════

  immich-server:
    image: ghcr.io/immich-app/immich-server:{{ immich_version }}
    container_name: immich-server
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    depends_on:
      - immich-db
      - immich-redis
    environment:
      - DB_HOSTNAME=immich-db
      - DB_USERNAME={{ vault_immich_db_user }}
      - DB_PASSWORD={{ vault_immich_db_password }}
      - DB_DATABASE_NAME={{ vault_immich_db_name }}
      - REDIS_HOSTNAME=immich-redis
    volumes:
      - {{ pi_stack_dir }}/immich/upload:/usr/src/app/upload
      - /etc/localtime:/etc/localtime:ro
    ports:
      - '{{ nb_ip }}:8094:2283'
    networks:
      - brain_private
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:2283/api/server/ping"]
      interval: 30s
      timeout: 10s
      retries: 3

  immich-machine-learning:
    image: ghcr.io/immich-app/immich-machine-learning:{{ immich_version }}
    container_name: immich-machine-learning
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ pi_stack_dir }}/immich/model-cache:/cache
    networks:
      - brain_private
    healthcheck:
      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:3003/ping')"]
      interval: 30s
      timeout: 10s
      retries: 3

  immich-redis:
    image: redis:{{ immich_redis_version }}
    container_name: immich-redis
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3
    networks:
      - brain_private

  immich-db:
    image: tensorchord/pgvecto-rs:{{ immich_db_version }}
    container_name: immich-db
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - POSTGRES_USER={{ vault_immich_db_user }}
      - POSTGRES_PASSWORD={{ vault_immich_db_password }}
      - POSTGRES_DB={{ vault_immich_db_name }}
      - POSTGRES_INITDB_ARGS='--data-checksums'
    volumes:
      - {{ pi_stack_dir }}/immich/db:/var/lib/postgresql/data
    networks:
      - brain_private
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d {{ vault_immich_db_name }} -U {{ vault_immich_db_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ══ MONITORING ═════════════════════════════════════════════════════════════

  node-exporter:
    image: prom/node-exporter:{{ node_exporter_version }}
    container_name: node-exporter
    restart: unless-stopped
    pid: host
    ports:
      - '{{ nb_ip }}:9100:9100'
    volumes:
      - /:/host:ro,rslave
    command:
      - '--path.rootfs=/host'
    networks:
      - brain_private

  # Note : Grafana/VictoriaMetrics/vmagent supprimés — remplacés par Bientôt
  # (projet externe déployé par son propre rôle Ansible)

  adguard:
    image: adguard/adguardhome:{{ adguard_version }}
    container_name: adguard
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ pi_stack_dir }}/adguard/work:/opt/adguardhome/work
      - {{ pi_stack_dir }}/adguard/conf:/opt/adguardhome/conf
    ports:
      - '{{ nb_ip }}:5353:53/tcp'
      - '{{ nb_ip }}:5353:53/udp'
      - '{{ nb_ip }}:3000:3000'
    networks:
      - brain_private

  adguard-exporter:
    image: ebrianne/adguard-exporter:{{ adguard_exporter_version }}
    container_name: adguard-exporter
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - adguard_protocol=http
      - adguard_hostname=adguard
      - adguard_username={{ vault_adguard_admin_user }}
      - adguard_password={{ vault_adguard_admin_password }}
      - adguard_port=3000
      - server_port=9617
      - log_limit=10000
    depends_on:
      - adguard
    networks:
      - brain_private

networks:
  brain_public:
    driver: bridge
    name: brain_public

  brain_private:
    driver: bridge
    name: brain_private
