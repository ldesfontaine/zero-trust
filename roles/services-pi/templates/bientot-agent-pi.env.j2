# Managed by Ansible — ne pas modifier manuellement
# Secrets Bientôt agent Pi — déployé mode 0600

# --- Agent Bientôt Pi ---
# L'agent collecte via les APIs des services sur brain_private
# Seul volume monté : docker.sock (inventaire containers) + /status (backup status)
BIENTOT_SERVER_URL=http://bientot-server:{{ bientot_agent_port }}
BIENTOT_MACHINE_ID=cerveau
BIENTOT_TOKEN={{ vault_bientot_token_pi }}
DOCKER_HOST=unix:///var/run/docker.sock

# --- URLs des APIs locales (brain_private) ---
NODE_EXPORTER_URL=http://node-exporter:9100
ADGUARD_URL=http://adguard:3000
ADGUARD_USER={{ vault_adguard_admin_user }}
ADGUARD_PASSWORD={{ vault_adguard_admin_password }}

# --- Vérification TLS + détection mesh ---
CERT_DOMAINS={{ cert_check_domains | default('') }}
NETBIRD_PEER_IP={{ vault_vps_netbird_ip }}
NETBIRD_PEER_PORT=443
