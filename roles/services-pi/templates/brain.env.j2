# Managed by Ansible — ne pas modifier manuellement
# Secrets injectés via ansible-vault → fichier .env déployé mode 0600

# --- Seafile ---
MYSQL_ROOT_PASSWORD={{ vault_seafile_db_root_password }}
DB_ROOT_PASSWD={{ vault_seafile_db_root_password }}
SEAFILE_ADMIN_EMAIL={{ vault_seafile_admin_email }}
SEAFILE_ADMIN_PASSWORD={{ vault_seafile_admin_password }}

# --- Vaultwarden ---
ADMIN_TOKEN={{ vault_vaultwarden_admin_token }}

# --- Immich ---
IMMICH_DB_USER={{ vault_immich_db_user }}
IMMICH_DB_PASSWORD={{ vault_immich_db_password }}
IMMICH_DB_NAME={{ vault_immich_db_name }}

# --- AdGuard ---
ADGUARD_USERNAME={{ vault_adguard_admin_user }}
ADGUARD_PASSWORD={{ vault_adguard_admin_password }}

# --- Bientôt server ---
{% set vps_nb = vault_vps_netbird_ip if vault_vps_netbird_ip not in ['CHANGE_ME', 'REMPLACER_APRES_ENROLEMENT_NETBIRD'] else '127.0.0.1' %}
NTFY_SERVER_URL={{ vault_ntfy_server_url | default('https://' + ntfy_subdomain + '.' + vault_base_domain) }}
NTFY_TOPIC={{ vault_ntfy_alert_topic | default('alerts') }}
NTFY_AUTH_TOKEN={{ vault_ntfy_auth_token }}
NODE_EXPORTER_PI_URL=http://{{ netbird_bind_ip }}:9100
NODE_EXPORTER_VPS_URL=http://{{ vps_nb }}:9100
CROWDSEC_METRICS_URL=http://{{ vps_nb }}:6060
BACKUP_STATUS_DIR=/data/backup/status
WEB_PORT={{ bientot_port }}

# --- Veille sécu ---
VEILLE_SECU_WEB_PORT={{ veille_secu_web_port }}
