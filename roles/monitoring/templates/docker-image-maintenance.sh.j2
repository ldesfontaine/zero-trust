#!/usr/bin/env bash
# Managed by Ansible — ne pas modifier manuellement
#
# Maintenance hebdomadaire des images Docker
# - Prune les anciennes images
# - Scan Grype des images (--output json)
#   → envoie le JSON complet à Bientôt si configuré
#   → sinon, fallback sur comptage + Ntfy
# Les versions sont épinglées — les mises à jour passent par Ansible

set -euo pipefail

NTFY_URL="https://{{ ntfy_subdomain }}.{{ vault_base_domain }}/docker-maintenance"
NTFY_AUTH="Authorization: Bearer {{ vault_ntfy_auth_token }}"
LOG_PREFIX="[docker-maintenance]"
DATE=$(date '+%Y-%m-%d %H:%M')
SCAN_ALERTS=""
SCAN_TOTAL_VULNS=0

{% if scan_bientot_url | default('') %}
# Bientôt — envoi des résultats Grype pour corrélation CVE
BIENTOT_URL="{{ scan_bientot_url }}"
BIENTOT_TOKEN="{{ scan_bientot_token }}"
BIENTOT_MACHINE="{{ scan_bientot_machine_id }}"
BIENTOT_ENABLED=true
{% else %}
BIENTOT_ENABLED=false
{% endif %}

echo "${LOG_PREFIX} ${DATE} — Début de la maintenance"

# --- 1. Prune des anciennes images ---
echo "${LOG_PREFIX} Prune des images non utilisées..."
PRUNE_OUTPUT=$(docker image prune -af --filter "until={{ docker_image_prune_age }}" 2>&1)
echo "${PRUNE_OUTPUT}"

# --- 2. Scan Grype (CVE — format JSON) ---
echo "${LOG_PREFIX} Scan Grype des images en cours d'exécution..."

for IMAGE in $(docker ps --format '{% raw %}{{.Image}}{% endraw %}' | sort -u); do
  echo "${LOG_PREFIX} Scan: ${IMAGE}"
  GRYPE_JSON=$(grype "${IMAGE}" --output json --only-fixed 2>/dev/null) || {
    echo "${LOG_PREFIX} WARN: échec du scan Grype pour ${IMAGE}"
    continue
  }

  VULN_COUNT=$(echo "${GRYPE_JSON}" | jq '[.matches // [] | length]')

  if [ "${BIENTOT_ENABLED}" = "true" ]; then
    # Envoi du JSON complet à Bientôt pour corrélation CVE
    INGEST_PAYLOAD=$(jq -n \
      --arg machine "${BIENTOT_MACHINE}" \
      --arg image "${IMAGE}" \
      --argjson results "${GRYPE_JSON}" \
      '{machine: $machine, image: $image, results: $results}')

    HTTP_CODE=$(curl -sf -o /dev/null -w '%{http_code}' \
      -X POST \
      -H "Authorization: Bearer ${BIENTOT_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "${INGEST_PAYLOAD}" \
      "${BIENTOT_URL}/scan/ingest" 2>/dev/null) || HTTP_CODE="000"

    if [ "${HTTP_CODE}" = "200" ]; then
      echo "${LOG_PREFIX} Bientôt: ${IMAGE} — ${VULN_COUNT} CVE envoyées"
    else
      echo "${LOG_PREFIX} WARN: Bientôt ingest échoué (HTTP ${HTTP_CODE}) pour ${IMAGE}"
    fi
  fi

  if [ "${VULN_COUNT}" -gt 0 ]; then
    SCAN_ALERTS="${SCAN_ALERTS}\n${IMAGE}: ${VULN_COUNT} vulnérabilités avec fix disponible"
    SCAN_TOTAL_VULNS=$((SCAN_TOTAL_VULNS + VULN_COUNT))
    echo "${LOG_PREFIX} ALERTE: ${IMAGE} — ${VULN_COUNT} CVE"
  fi
done

# --- 3. Notification Ntfy (résumé maintenance) ---
if [ -n "${SCAN_ALERTS}" ]; then
  if [ "${BIENTOT_ENABLED}" = "true" ]; then
    # Bientôt gère les détails — Ntfy ne fait qu'un résumé court
    BODY="Scan Grype terminé — ${SCAN_TOTAL_VULNS} CVE détectées. Détails dans Bientôt."
  else
    BODY="Scan sécurité — vulnérabilités détectées:\n${SCAN_ALERTS}"
  fi
  PRIORITY="high"
  TAGS="warning"
  TITLE="Docker Maintenance — CVE détectées"
else
  BODY="Aucune CVE critique sur $(hostname)"
  PRIORITY="low"
  TAGS="white_check_mark"
  TITLE="Docker Maintenance — RAS"
fi

curl -s \
  -H "${NTFY_AUTH}" \
  -H "Title: ${TITLE}" \
  -H "Priority: ${PRIORITY}" \
  -H "Tags: ${TAGS}" \
  -d "$(echo -e "${BODY}")" \
  "${NTFY_URL}" || echo "${LOG_PREFIX} WARN: notification Ntfy échouée"

echo "${LOG_PREFIX} ${DATE} — Maintenance terminée"
