# ============================================================================
# Traefik Dynamic Config — Services Pi publics via NetBird mesh
# Managed by Ansible — ne pas modifier manuellement
#
# Ce fichier est lu par le provider "file" de Traefik.
# Il déclare les routers et services pour pdf + portfolio,
# qui sont hébergés sur le Pi mais accessibles publiquement via le VPS.
#
# Flux : visiteur → HTTPS VPS → Traefik → NetBird mesh → Pi:port
#
# Disponible uniquement quand le mesh est operationnel (netbird_mesh_ready).
# Sinon, ce fichier contient une config vide (pas de routing Pi actif).
#
# vault_pi_netbird_ip est un alias cross-host derive de
# hostvars['pi_serv'].host_netbird_ip (group_vars/all.yml).
# ============================================================================

{% set pi_ip_ready = vault_pi_netbird_ip not in ['CHANGE_ME', 'REMPLACER_APRES_ENROLEMENT_NETBIRD'] %}
{% if not ((netbird_mesh_ready | default(false) | bool) and pi_ip_ready) %}
# Mesh VPS non operationnel ou IP Pi non renseignee — routing Pi desactive
# Relancer Ansible apres enrollment NetBird pour activer pdf + portfolio publics
{}
{% else %}
http:

  # ── Middlewares ─────────────────────────────────────────────────────────────

  middlewares:

    # Whitelist NetBird — restreint les services privés aux peers du mesh
    # Les services publics (pdf, portfolio) n'utilisent PAS ce middleware
    netbird-only:
      ipAllowList:
        sourceRange:
          - "100.64.0.0/10"   # plage CGNAT NetBird (couvre 100.x.x.x)
          - "127.0.0.1/32"    # loopback (health checks locaux)

  # ── Routers ────────────────────────────────────────────────────────────────

  routers:

    # BentoPDF — public, protégé par CrowdSec (via nftables hôte)
    pi-pdf:
      rule: "Host(`{{ bentopdf_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      service: pi-pdf
      priority: 10

    # Portfolio — public, protégé par CrowdSec (via nftables hôte)
    pi-portfolio:
      rule: "Host(`{{ portfolio_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      service: pi-portfolio
      priority: 10

    # ── Services privés (VPN NetBird requis) ────────────────────────────────
    # Accessibles uniquement depuis le réseau mesh (whitelist 100.64.0.0/10)
    # DNS : AdGuard rewrite → VPS IP → Traefik → Pi via NetBird

    pi-seafile:
      rule: "Host(`{{ seafile_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-seafile
      priority: 10

    pi-vaultwarden:
      rule: "Host(`{{ vaultwarden_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-vaultwarden
      priority: 10

    pi-adguard:
      rule: "Host(`{{ adguard_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-adguard
      priority: 10

    pi-immich:
      rule: "Host(`{{ immich_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-immich
      priority: 10

    # Bientôt — panel admin privé (monitoring, métriques, alerting)
    pi-bientot:
      rule: "Host(`{{ bientot_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-bientot
      priority: 10

  # ── Services (backends sur le Pi via tunnel NetBird) ───────────────────────

  services:

    pi-pdf:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8090"
        passHostHeader: true

    pi-portfolio:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8091"
        passHostHeader: true

    pi-seafile:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8092"
        passHostHeader: true

    pi-vaultwarden:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8093"
        passHostHeader: true

    pi-adguard:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:3000"
        passHostHeader: true

    pi-immich:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:{{ immich_port }}"
        passHostHeader: true

    pi-bientot:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:{{ bientot_port }}"
        passHostHeader: true

{% endif %}
