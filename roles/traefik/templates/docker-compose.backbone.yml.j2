# ============================================================================
# Docker Compose Backbone — Managed by Ansible
#
# Infrastructure critique L3 : Traefik (reverse proxy + TLS) + NetBird server
# Deploye AVANT les services applicatifs (L4) et l'enrollment NetBird (L3c).
#
# Le reseau sentinel_net est cree en amont par Ansible (docker_network).
# Les services L4 dans /opt/sentinel/ rejoignent ce meme reseau.
# ============================================================================

services:

  # == REVERSE PROXY ===========================================================

  traefik:
    image: traefik:{{ traefik_version }}
    container_name: traefik
    restart: unless-stopped
    command:
      # Provider Docker (containers locaux — backbone + services L4)
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.docker.network=sentinel_net"
      # Provider fichier (services Pi via NetBird mesh)
      - "--providers.file.directory=/etc/traefik/dynamic"
      - "--providers.file.watch=true"
      # Entrypoints
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      # Timeout infini pour gRPC long-lived connections (NetBird)
      - "--entrypoints.websecure.transport.respondingTimeouts.readTimeout=0"
      # Redirect HTTP -> HTTPS
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
      # Let's Encrypt TLS Challenge
      - "--certificatesresolvers.letsencrypt.acme.tlschallenge=true"
      - "--certificatesresolvers.letsencrypt.acme.email={{ vault_admin_email }}"
      - "--certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json"
      # Healthcheck ping endpoint (interne uniquement)
      - "--ping=true"
      - "--ping.entrypoint=web"
      # Logs
      - "--log.level=INFO"
      - "--accesslog=true"
    ports:
      - '80:80'
      - '443:443'
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik_letsencrypt:/letsencrypt
      - {{ backbone_dir }}/traefik/dynamic:/etc/traefik/dynamic:ro
    networks:
      - sentinel_net
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:80/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3

volumes:
  traefik_letsencrypt:

networks:
  sentinel_net:
    external: true
