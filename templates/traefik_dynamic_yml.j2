# ============================================================================
# Traefik Dynamic Config — Services Pi publics via NetBird mesh
# Managed by Ansible — ne pas modifier manuellement
#
# Ce fichier est lu par le provider "file" de Traefik.
# Il déclare les routers et services pour pdf + portfolio,
# qui sont hébergés sur le Pi mais accessibles publiquement via le VPS.
#
# Flux : visiteur → HTTPS VPS → Traefik → NetBird mesh → Pi:port
#
# Disponible uniquement au Run 2 (vault_pi_netbird_ip renseigné).
# Au Run 1, ce fichier contient une config vide (pas de routing Pi actif).
# ============================================================================

{% if vault_pi_netbird_ip == "REMPLACER_APRES_ENROLEMENT_NETBIRD" %}
# Pi pas encore enrôlé — routing désactivé
# Relancer Ansible après enrollment pour activer pdf + portfolio publics
{}
{% else %}
http:

  # ── Middlewares ─────────────────────────────────────────────────────────────

  middlewares:

    # Whitelist NetBird — restreint les services privés aux peers du mesh
    # Les services publics (pdf, portfolio) n'utilisent PAS ce middleware
    netbird-only:
      ipWhiteList:
        sourceRange:
          - "100.64.0.0/10"   # plage CGNAT NetBird (couvre 100.x.x.x)
          - "127.0.0.1/32"    # loopback (health checks locaux)

  # ── Routers ────────────────────────────────────────────────────────────────

  routers:

    # BentoPDF — public, protégé par CrowdSec (via nftables hôte)
    pi-pdf:
      rule: "Host(`{{ bentopdf_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      service: pi-pdf
      priority: 10

    # Portfolio — public, protégé par CrowdSec (via nftables hôte)
    pi-portfolio:
      rule: "Host(`{{ portfolio_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      service: pi-portfolio
      priority: 10

    # ── Services privés (VPN NetBird requis) ────────────────────────────────
    # Accessibles uniquement depuis le réseau mesh (whitelist 100.64.0.0/10)
    # DNS : AdGuard rewrite → VPS IP → Traefik → Pi via NetBird

    pi-nextcloud:
      rule: "Host(`{{ nextcloud_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-nextcloud
      priority: 10

    pi-vaultwarden:
      rule: "Host(`{{ vaultwarden_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-vaultwarden
      priority: 10

    pi-grafana:
      rule: "Host(`{{ grafana_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-grafana
      priority: 10

    pi-adguard:
      rule: "Host(`{{ adguard_subdomain }}.{{ vault_base_domain }}`)"
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - netbird-only
      service: pi-adguard
      priority: 10

  # ── Services (backends sur le Pi via tunnel NetBird) ───────────────────────

  services:

    pi-pdf:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8090"
        passHostHeader: true

    pi-portfolio:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8091"
        passHostHeader: true

    pi-nextcloud:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8092"
        passHostHeader: true

    pi-vaultwarden:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:8093"
        passHostHeader: true

    pi-grafana:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:3001"
        passHostHeader: true

    pi-adguard:
      loadBalancer:
        servers:
          - url: "http://{{ vault_pi_netbird_ip }}:3000"
        passHostHeader: true

{% endif %}
