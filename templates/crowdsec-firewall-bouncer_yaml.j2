# ============================================================================
# CrowdSec Firewall Bouncer — Configuration nftables
# Managed by Ansible — ne pas modifier manuellement
# Doc : https://docs.crowdsec.net/docs/bouncers/firewall/
# ============================================================================

# --- Mode de fonctionnement ---
mode: nftables                     # Utilise nftables (pas iptables)
pid_dir: /var/run/
update_frequency: 10s              # Interroge la LAPI toutes les 10 secondes
daemonize: true

# --- Logs ---
log_mode: file
log_dir: /var/log/
log_level: info
log_compression: true
log_max_size: 100                  # Mo
log_max_backups: 3
log_max_age: 30                    # Jours

# --- Connexion à la LAPI CrowdSec (dans Docker) ---
api_url: http://127.0.0.1:8080/
api_key: {{ vault_crowdsec_lapi_key }}
insecure_skip_verify: false

# --- Comportement ---
disable_ipv6: false
deny_action: DROP                  # DROP = silencieux (l'attaquant ne sait pas qu'il est bloqué)
deny_log: true                     # Log les IPs bloquées dans /var/log/
deny_log_prefix: "crowdsec: "     # Préfixe pour identifier dans les logs

# Types de décisions à appliquer
supported_decisions_types:
  - ban

# --- Tables nftables ---
# Le bouncer crée automatiquement ces tables et les alimente avec les IPs bannies
nftables:
  ipv4:
    enabled: true
    set-only: false
    table: crowdsec
    chain: crowdsec-chain
    priority: -10                  # Priorité haute = traité avant les autres règles
  ipv6:
    enabled: true
    set-only: false
    table: crowdsec6
    chain: crowdsec6-chain
    priority: -10
