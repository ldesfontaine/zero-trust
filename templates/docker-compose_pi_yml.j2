# ============================================================================
# Docker Compose Stack Pi — Managed by Ansible
# ============================================================================

{# Résolution de l'IP de binding : IP NetBird si disponible, sinon 127.0.0.1 #}
{% if vault_pi_netbird_ip == "REMPLACER_APRES_ENROLEMENT_NETBIRD" %}
{% set nb_ip = "127.0.0.1" %}
{% else %}
{% set nb_ip = vault_pi_netbird_ip %}
{% endif %}

services:

  # ══ RÉSEAU PUBLIC (accessibles via VPS → mesh → Pi, sans client VPN) ══════

  bentopdf:
    image: {{ bentopdf_image }}:{{ bentopdf_version }}
    container_name: bentopdf
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    ports:
      - '{{ nb_ip }}:8090:8080'
    networks:
      - brain_public

  portfolio:
    image: termfolio:local  # Utilise l'image construite localement sur le Pi
    container_name: portfolio
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    ports:
      - '{{ nb_ip }}:8091:80'
    networks:
      - brain_public

  # ══ RÉSEAU PRIVÉ (admin VPN seulement) ═════════════════════════════════════

  nextcloud-db:
    image: mariadb:{{ mariadb_version }}
    container_name: nextcloud-db
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - MYSQL_ROOT_PASSWORD={{ vault_nextcloud_db_password }}
      - MYSQL_DATABASE=nextcloud
      - MYSQL_USER=nextcloud
      - MYSQL_PASSWORD={{ vault_nextcloud_db_password }}
    volumes:
      - {{ pi_stack_dir }}/nextcloud/db:/var/lib/mysql
    networks:
      - brain_private

  nextcloud:
    image: nextcloud:{{ nextcloud_version }}
    container_name: nextcloud
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    depends_on:
      - nextcloud-db
    environment:
      - MYSQL_HOST=nextcloud-db
      - MYSQL_DATABASE=nextcloud
      - MYSQL_USER=nextcloud
      - MYSQL_PASSWORD={{ vault_nextcloud_db_password }}
      - NEXTCLOUD_ADMIN_USER={{ vault_nextcloud_admin_user }}
      - NEXTCLOUD_ADMIN_PASSWORD={{ vault_nextcloud_admin_password }}
      # Domaines de confiance : IP NetBird Pi + FQDN public (Traefik)
      - NEXTCLOUD_TRUSTED_DOMAINS={{ nb_ip }} {{ nextcloud_subdomain }}.{{ vault_base_domain }}
      # Config reverse proxy HTTPS (Traefik termine le TLS)
      - OVERWRITEPROTOCOL=https
      - OVERWRITEHOST={{ nextcloud_subdomain }}.{{ vault_base_domain }}
      - OVERWRITECLIURL=https://{{ nextcloud_subdomain }}.{{ vault_base_domain }}
      # Traefik forwarde X-Forwarded-For — faire confiance aux IPs du mesh NetBird
      - TRUSTED_PROXIES={{ vault_vps_netbird_ip }}
    volumes:
      - {{ pi_stack_dir }}/nextcloud/data:/var/www/html
    ports:
      - '{{ nb_ip }}:8092:80'
    networks:
      - brain_private

  vaultwarden:
    image: vaultwarden/server:{{ vaultwarden_version }}
    container_name: vaultwarden
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - ADMIN_TOKEN={{ vault_vaultwarden_admin_token }}
      - DOMAIN=https://{{ vaultwarden_subdomain }}.{{ vault_base_domain }}
      - SIGNUPS_ALLOWED=false
    volumes:
      - {{ pi_stack_dir }}/vaultwarden:/data
    ports:
      - '{{ nb_ip }}:8093:80'
    networks:
      - brain_private

  # ══ MONITORING ═════════════════════════════════════════════════════════════

  node-exporter:
    image: prom/node-exporter:{{ node_exporter_version }}
    container_name: node-exporter
    restart: unless-stopped
    pid: host
    ports:
      - '{{ nb_ip }}:9100:9100'
    volumes:
      - /:/host:ro,rslave
    command:
      - '--path.rootfs=/host'
    networks:
      - brain_private

  victoriametrics:
    image: victoriametrics/victoria-metrics:{{ victoriametrics_version }}
    container_name: victoriametrics
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ pi_stack_dir }}/victoriametrics:/storage
    command:
      - '--storageDataPath=/storage'
      - '--retentionPeriod=12'
    ports:
      - '127.0.0.1:8428:8428'
    networks:
      - brain_private

  vmagent:
    image: victoriametrics/vmagent:{{ victoriametrics_version }}
    container_name: vmagent
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ pi_stack_dir }}/victoriametrics/vmagent-config/vmagent-config.yml:/etc/vmagent/config.yml:ro
    command:
      - '--promscrape.config=/etc/vmagent/config.yml'
      - '--remoteWrite.url=http://victoriametrics:8428/api/v1/write'
    depends_on:
      - victoriametrics
    networks:
      - brain_private

  grafana:
    image: grafana/grafana:{{ grafana_version }}
    container_name: grafana
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ vault_grafana_admin_password }}
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_SERVER_ROOT_URL=https://{{ grafana_subdomain }}.{{ vault_base_domain }}
    volumes:
      - {{ pi_stack_dir }}/grafana:/var/lib/grafana
      - {{ pi_stack_dir }}/grafana-provisioning/datasources:/etc/grafana/provisioning/datasources:ro
    ports:
      - '{{ nb_ip }}:3001:3000'
    depends_on:
      - victoriametrics
    networks:
      - brain_private

  adguard:
    image: adguard/adguardhome:{{ adguard_version }}
    container_name: adguard
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ pi_stack_dir }}/adguard/work:/opt/adguardhome/work
      - {{ pi_stack_dir }}/adguard/conf:/opt/adguardhome/conf
    ports:
      - '{{ nb_ip }}:5353:53/tcp'
      - '{{ nb_ip }}:5353:53/udp'
      - '{{ nb_ip }}:3000:3000'
    networks:
      - brain_private

  adguard-exporter:
    image: ebrianne/adguard-exporter:{{ adguard_exporter_version }}
    container_name: adguard-exporter
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - adguard_protocol=http
      - adguard_hostname=adguard
      - adguard_username={{ vault_adguard_admin_user }}
      - adguard_password={{ vault_adguard_admin_password }}
      - adguard_port=3000
      - server_port=9617
      - log_limit=10000
    depends_on:
      - adguard
    networks:
      - brain_private

networks:
  brain_public:
    driver: bridge
    name: brain_public

  brain_private:
    driver: bridge
    name: brain_private
