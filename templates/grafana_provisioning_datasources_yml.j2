# ============================================================
# Grafana — Datasource provisioning — Managed by Ansible
# Provisionne VictoriaMetrics comme datasource par défaut
# au démarrage du container (pas besoin de config manuelle).
# ============================================================
apiVersion: 1

datasources:
  - name: VictoriaMetrics
    type: prometheus
    uid: victoriametrics
    access: proxy
    url: http://victoriametrics:8428
    isDefault: true
    editable: false
    jsonData:
      timeInterval: "30s"
