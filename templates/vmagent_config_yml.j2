# ============================================================================
# vmagent — Configuration de scrape
# Managed by Ansible
#
# Services Pi locaux  : noms de containers (même réseau brain_private)
# Services VPS distants : IP NetBird (tunnel WireGuard)
#
# Premier run  (IPs placeholder) : scraping VPS désactivé (127.0.0.1)
# Second run   (IPs renseignées) : scraping Pi + VPS via tunnel NetBird
# ============================================================================

{# IP VPS avec fallback 127.0.0.1 si non encore enrôlé #}
{% if vault_vps_netbird_ip == "REMPLACER_APRES_ENROLEMENT_NETBIRD" %}
{% set vps_ip = "127.0.0.1" %}
{% else %}
{% set vps_ip = vault_vps_netbird_ip %}
{% endif %}

global:
  scrape_interval: 30s
  scrape_timeout: 10s

scrape_configs:

  # Pi — container name (même réseau brain_private, pas besoin d'IP)
  - job_name: 'node-pi'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: 'pi'
          role: 'cerveau'

  - job_name: 'adguard-pi'
    static_configs:
      - targets: ['adguard-exporter:9617']
        labels:
          instance: 'pi'
          role: 'cerveau'

  # VPS — IP NetBird (machine distante)
  - job_name: 'node-vps'
    static_configs:
      - targets: ['{{ vps_ip }}:9100']
        labels:
          instance: 'vps'
          role: 'sentinelle'

  - job_name: 'crowdsec-vps'
    static_configs:
      - targets: ['{{ vps_ip }}:6060']
        labels:
          instance: 'vps'
          role: 'sentinelle'
