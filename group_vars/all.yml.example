# ══════════════════════════════════════════
# INFRASTRUCTURE ZERO TRUST — Configuration globale
# Source de vérité unique pour les 2 machines.
# Copier vers all.yml et remplir les valeurs CHANGE_ME.
# Chiffrer ensuite : ansible-vault encrypt group_vars/all.yml
# ══════════════════════════════════════════


# ══════════════════════════════════════════
# DOMAINES ET RÉSEAU
# ══════════════════════════════════════════

# ── OBLIGATOIRE ───────────────────────────
vault_base_domain: "CHANGE_ME"                # Domaine principal (ex: example.com)
vault_admin_email: "CHANGE_ME"                # Email admin Let's Encrypt (ex: admin@example.com)
vault_ssh_user: "CHANGE_ME"                   # User admin SSH sur les 2 machines

# Sous-domaines (tous pointent vers l'IP publique VPS)
netbird_subdomain: "mesh"
ntfy_subdomain: "ntfy"
seafile_subdomain: "cloud"
vaultwarden_subdomain: "vault"
immich_subdomain: "photos"
adguard_subdomain: "adguard"
bientot_subdomain: "bientot"
bentopdf_subdomain: "pdf"
portfolio_subdomain: "portfolio"

# FQDNs dérivés (calculés — ne pas modifier)
netbird_fqdn: "{{ netbird_subdomain }}.{{ vault_base_domain }}"

# NetBird IPs WireGuard (aliases cross-host)
# La source de vérité est host_netbird_ip dans chaque host_vars/.
# Ces variables dérivées permettent aux templates cross-host (bientot.env,
# traefik_dynamic, netbird-acl) de référencer l'IP d'une autre machine.
vault_vps_netbird_ip: "{{ hostvars['vps_serv'].host_netbird_ip | default('CHANGE_ME') }}"
vault_pi_netbird_ip: "{{ hostvars['pi_serv'].host_netbird_ip | default('CHANGE_ME') }}"

# ── OPTIONNEL ─────────────────────────────
vault_ssh_port: 2222                          # Port SSH custom (identique VPS + Pi)
vault_pi_ssh_user: "lucas"                    # User SSH sur le Pi (si différent de vault_ssh_user)
router_ip: "192.168.1.1"                     # IP du routeur/Livebox (split DNS .home AdGuard)


# ══════════════════════════════════════════
# SSH ET DÉPLOIEMENT
# ══════════════════════════════════════════

# ── OBLIGATOIRE ───────────────────────────
ssh_key_path: "~/.ssh/id_ed25519_vps_homelab.pub"    # Clé publique admin
priv_ssh_key_path: "~/.ssh/id_ed25519_vps_homelab"   # Clé privée admin (backup, restore, connection-resolver)

# User deploy (CI/CD)
vault_deploy_user: "deploy"
deploy_ssh_key_path: "~/.ssh/id_ed25519_deploy.pub"  # Clé publique user deploy

# Repo Ansible sur le VPS (cloné par le user deploy au bootstrap)
deploy_repo_url: "https://github.com/ldesfontaine/zero-trust.git"
deploy_repo_path: "/home/deploy/deployVps"


# ══════════════════════════════════════════
# PORTS DES SERVICES
# ══════════════════════════════════════════

# Ports de binding sur le Pi (IP NetBird uniquement)
# Source unique pour nftables, Docker compose, Traefik et ACLs NetBird
bentopdf_port: "8090"
portfolio_port: "8091"
seafile_port: "8092"
vaultwarden_port: "8093"
veille_secu_web_port: "8094"
immich_port: "8096"
adguard_ui_port: "3000"
bientot_port: "3001"                          # Dashboard (Traefik)
bientot_agent_port: "3002"                    # Push agents (mesh direct)


# ══════════════════════════════════════════
# VERSIONS DES IMAGES DOCKER
# → Déplacées dans group_vars/versions.yml (non chiffré)
# → Voir versions.yml.example
# ══════════════════════════════════════════


# ══════════════════════════════════════════
# CONFIG VEILLE-SÉCU
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
veille_secu_watch_stack: "traefik,seafile,vaultwarden,docker,linux,netbird,crowdsec"
veille_secu_cron_interval: "3600"             # Intervalle de scraping (secondes)
veille_secu_ntfy_topic: "veille-secu"         # Topic Ntfy dédié
veille_secu_manual_cooldown: "900"            # Cooldown entre 2 scans manuels (secondes)


# ══════════════════════════════════════════
# CONFIG PORTFOLIO
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
portfolio_site_url: "https://{{ portfolio_subdomain }}.{{ vault_base_domain }}"


# ══════════════════════════════════════════
# CERTIFICATS TLS (module Bientôt certificates)
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
cert_check_domains: "{{ bentopdf_subdomain }}.{{ vault_base_domain }},{{ portfolio_subdomain }}.{{ vault_base_domain }},{{ seafile_subdomain }}.{{ vault_base_domain }},{{ vaultwarden_subdomain }}.{{ vault_base_domain }}"


# ══════════════════════════════════════════
# NTFY (optionnel — valeurs par défaut via roles/defaults)
# ══════════════════════════════════════════

# Ces variables vault permettent d'override les valeurs dérivées.
# Si absentes, le système utilise : https://ntfy.<vault_base_domain>
# vault_ntfy_server_url: "https://ntfy.example.com"     # Défaut: https://ntfy.<vault_base_domain>
# vault_ntfy_alert_topic: "alerts"                       # Défaut: alerts
# vault_ntfy_backup_topic: "backup"                      # Défaut: backup (topic backup scripts)

# Les seuils d'alerte (disk, RAM, CPU, backup, TLS, ZFS) sont gérés
# par Bientôt dans bientot/config/alerts.yml — NE PLUS les définir ici.


# ══════════════════════════════════════════
# POLITIQUE DE RÉTENTION (backup)
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
backup_vps_retention_days: 7                  # Rétention backup GPG sur le VPS (jours)
backup_disk_warn_pct: 80                      # Seuil disque dans le script backup
zfs_snap_hourly_keep: 24                      # Snapshots ZFS horaires à garder
zfs_snap_daily_keep: 7                        # Snapshots ZFS journaliers à garder
zfs_snap_monthly_keep: 6                      # Snapshots ZFS mensuels à garder
backup_usb_snap_keep: 3                       # Snapshots USB à garder


# ══════════════════════════════════════════
# MAINTENANCE DOCKER
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
docker_image_prune_age: "168h"                # Suppression images non utilisées > 7 jours
docker_maintenance_cron_hour: "4"             # Heure du cron maintenance (UTC)
docker_maintenance_cron_weekday: "0"          # Jour du cron (0=dimanche)


# ══════════════════════════════════════════
# TRAEFIK
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
traefik_rate_limit_average: 50                # Rate limit services publics (req/s)
traefik_rate_limit_burst: 100                 # Burst max
traefik_hsts_max_age: 31536000                # HSTS max-age en secondes (1 an)


# ══════════════════════════════════════════
# SSH HARDENING
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
ssh_max_auth_tries: 3                         # Tentatives max avant déconnexion
ssh_max_sessions: 5                           # Sessions simultanées max
ssh_client_alive_interval: 30                 # Keepalive SSH (secondes)
ssh_client_alive_count_max: 6                 # Keepalives sans réponse avant déconnexion


# ══════════════════════════════════════════
# CROWDSEC
# ══════════════════════════════════════════

# ── OPTIONNEL ─────────────────────────────
crowdsec_log_max_size_mb: 100                 # Taille max log bouncer (MB)
crowdsec_log_max_age_days: 30                 # Rétention logs bouncer (jours)
