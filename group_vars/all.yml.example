# ============================================================================
# Variables globales — Copier vers all.yml et remplir les valeurs
# Chiffrer ensuite : ansible-vault encrypt group_vars/all.yml
# ============================================================================

# --- Versions Docker images ---
traefik_version: "v2.11"
crowdsec_version: "v1.6.8"
netbird_server_version: "0.36.5"
netbird_dashboard_version: "2.9.0"
node_exporter_version: "v1.9.0"
mariadb_version: "11"
seafile_version: "11.0-latest"
memcached_version: "1.6"
vaultwarden_version: "1.32.1"
adguard_version: "v0.107.55"
bentopdf_image: "ghcr.io/alam00000/bentopdf"
bentopdf_version: "sha-latest"  # Épingler : ghcr.io/alam00000/bentopdf → remplacer par sha-<commit> stable
ntfy_version: "v2.11.0"
docker_socket_proxy_version: "0.2.0"
# --- Images perso : latest intentionnel — image-maintenance met à jour auto (dimanche 04:00 UTC)
portfolio_image: "ghcr.io/ldesfontaine/termfolio"
portfolio_version: "latest"
bientot_server_image: "ghcr.io/ldesfontaine/bientot-server"
bientot_server_version: "latest"
bientot_agent_image: "ghcr.io/ldesfontaine/bientot-agent"
bientot_agent_version: "latest"
veille_secu_image: "ghcr.io/ldesfontaine/vielle-technologique"
veille_secu_version: "latest"
immich_version: "v1.134.0"
immich_redis_version: "7-alpine"
immich_db_image: "ghcr.io/immich-app/postgres"
immich_db_version: "14-vectorchord0.3.0-pgvectors0.2.0"

# --- Domaine de base ---
vault_base_domain: "CHANGE_ME"                 # ex: example.com
vault_admin_email: "CHANGE_ME"                 # ex: admin@example.com

# --- Sous-domaines VPS (exposés publiquement via Traefik + Let's Encrypt) ---
netbird_subdomain: "mesh"

# --- Sous-domaines Pi publics (exposés via VPS → mesh → Pi) ---
bentopdf_subdomain: "pdf"
portfolio_subdomain: "portfolio"

# --- Sous-domaines Pi privés (accessibles uniquement via client NetBird) ---
seafile_subdomain: "cloud"
vaultwarden_subdomain: "vault"
adguard_subdomain: "adguard"
immich_subdomain: "photos"
bientot_subdomain: "bientot"

# --- Sous-domaines VPS privés (accessibles via client NetBird) ---
ntfy_subdomain: "ntfy"

# --- FQDNs dérivés (calculés — ne pas modifier) ---
netbird_fqdn: "{{ netbird_subdomain }}.{{ vault_base_domain }}"

# --- SSH ---
ssh_key_path: "~/.ssh/id_ed25519_vps_homelab.pub"
priv_ssh_key_path: "~/.ssh/id_ed25519_vps_homelab"

# --- User deploy (CI/CD) ---
vault_deploy_user: "deploy"
deploy_ssh_key_path: "~/.ssh/id_ed25519_deploy.pub"

# --- Repo Ansible sur le VPS (cloné par le user deploy au bootstrap) ---
deploy_repo_url: "https://github.com/ldesfontaine/deployVps.git"
deploy_repo_path: "/home/deploy/deployVps"

# --- Connexion finale (Play 4) ---
vault_ssh_user: "lucas"
vault_ssh_port: 2222
vault_pi_ssh_user: "lucas"

# --- Ports applicatifs (Pi via VPS) ---
# Source unique pour nftables, Docker compose, Traefik et ACLs NetBird
bentopdf_port: "8090"
portfolio_port: "8091"
seafile_port: "8092"
vaultwarden_port: "8093"
veille_secu_web_port: "8094"
immich_port: "8096"
adguard_ui_port: "3000"
bientot_port: "3001"
bientot_agent_port: "3002"

# --- Config veille-sécu (variables lues par le container) ---
veille_secu_watch_stack: "traefik,seafile,vaultwarden,docker,linux,netbird,crowdsec"
veille_secu_cron_interval: "3600"
veille_secu_ntfy_topic: "veille-secu"
veille_secu_manual_cooldown: "900"

# --- Domaines à vérifier pour l'expiration TLS (optionnel) ---
cert_check_domains: "{{ bentopdf_subdomain }}.{{ vault_base_domain }},{{ portfolio_subdomain }}.{{ vault_base_domain }},{{ seafile_subdomain }}.{{ vault_base_domain }},{{ vaultwarden_subdomain }}.{{ vault_base_domain }}"

# --- Config portfolio ---
portfolio_site_url: "https://{{ portfolio_subdomain }}.{{ vault_base_domain }}"

# --- NetBird IPs WireGuard (aliases cross-host) ---
# La source de verite est host_netbird_ip dans chaque host_vars/.
# Ces variables derivees permettent aux templates cross-host (bientot.env,
# traefik_dynamic, netbird-acl) de referencer l'IP d'une autre machine.
vault_vps_netbird_ip: "{{ hostvars['vps_serv'].host_netbird_ip | default('CHANGE_ME') }}"
vault_pi_netbird_ip: "{{ hostvars['pi_serv'].host_netbird_ip | default('CHANGE_ME') }}"

# --- Réseau local ---
livebox_ip: "192.168.1.1"                      # IP du routeur/Livebox (split DNS .home)

# --- IP publique VPS ---
vault_vps_mgmt_ip: "CHANGE_ME"                 # IP publique de ton VPS
