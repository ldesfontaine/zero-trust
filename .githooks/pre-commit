#!/usr/bin/env bash
# Pre-commit hook : refuse tout vault.yml non chiffre.
# Detection : les 14 premiers octets doivent etre "$ANSIBLE_VAULT".

set -euo pipefail

fails=0
staged_vault_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)vault\.yml$' || true)

if [ -z "$staged_vault_files" ]; then
    exit 0
fi

while IFS= read -r file; do
    [ -z "$file" ] && continue
    header=$(git show ":$file" 2>/dev/null | head -c 14 || true)
    if [ "$header" != '$ANSIBLE_VAULT' ]; then
        echo "ERREUR: $file n'est pas chiffre avec ansible-vault" >&2
        fails=$((fails + 1))
    fi
done <<< "$staged_vault_files"

if [ "$fails" -gt 0 ]; then
    echo "" >&2
    echo "Commit refuse. Chiffre d'abord :" >&2
    echo "  ansible-vault encrypt <fichier>" >&2
    echo "" >&2
    echo "Pour bypasser ce hook (A EVITER) : git commit --no-verify" >&2
    exit 1
fi
